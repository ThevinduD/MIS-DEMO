@model MIS_DEMO.Models.ViewModels.Collection.CollectionDetailsViewModel

@{
    ViewData["Title"] = "Collection Details";
}

<div class="px-md-3 mt-4">
    <!-- CLEAN, RIGHT-ALIGNED BACK BUTTON -->
    <div class="text-end mb-3">
        <a class="btn btn-sm btn-outline-secondary mt-1" href="javascript:history.back()">Back</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <!-- Restored your original clean blue header -->
        <div class="card-header text-white d-flex flex-wrap justify-content-between align-items-center" style="background-color: #1e3a8a;">
            <h4 class="mb-0 me-3">Collection Details</h4>

            <form method="get" asp-action="Details" class="d-flex align-items-center flex-wrap gap-2 mt-2 mt-md-0">
                <input type="hidden" name="team" value="@Model.SelectedTeam" />

                <div class="d-flex align-items-center bg-white rounded px-2 py-1 shadow-sm">
                    <label class="fw-bold text-dark me-2 small mb-0">From:</label>
                    <input type="date" name="fromDate" class="form-control form-control-sm border-0 shadow-none p-0"
                           value="@Model.FromDate.ToString("yyyy-MM-dd")" style="outline: none;" />
                </div>

                <div class="d-flex align-items-center bg-white rounded px-2 py-1 shadow-sm">
                    <label class="fw-bold text-dark me-2 small mb-0">To:</label>
                    <input type="date" name="toDate" class="form-control form-control-sm border-0 shadow-none p-0"
                           value="@Model.ToDate.ToString("yyyy-MM-dd")" style="outline: none;" />
                </div>

                <button type="submit" class="btn btn-sm btn-light text-primary fw-bold shadow-sm px-3 ms-1">
                    <i class="bi bi-funnel-fill me-1"></i> Filter
                </button>
            </form>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-12">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-light fw-bold text-dark d-flex justify-content-between">
                    <span>Direct Cash</span>
                    <span class="text-primary">@Model.DirectPayments.Sum(x => x.TotalAmount).ToString("N0") LKR</span>
                </div>
                <div class="card-body p-0 table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-secondary sticky-top">
                            <tr><th>Receipt No</th><th>Receipt Date</th><th>Team</th><th class="text-end">Amount</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.DirectPayments)
                            {
                                <tr>
                                    <td class="fw-bold">
                                        <a asp-controller="Collection"
                                           asp-action="ReceiptDetails"
                                           asp-route-receiptNo="@row.ReceiptNo"
                                           asp-route-team="@row.Team"
                                           class="text-decoration-none">
                                            @row.ReceiptNo
                                        </a>
                                    </td>
                                    <td><span class="text-muted small">@(row.PayDate.HasValue? row.PayDate.Value.ToString("yyyy-MM-dd") : "-")</span></td>
                                    <td>@row.Team</td>
                                    <td class="text-end fw-bold">@row.TotalAmount.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-light fw-bold text-dark d-flex justify-content-between">
                    <span>Cheques Collected</span>
                    <span class="text-primary">@Model.ChequesCollected.Sum(x => x.TotalAmount).ToString("N0") LKR</span>
                </div>
                <div class="card-body p-0 table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-secondary sticky-top">
                            <tr><th>Receipt No</th><th>Cheque No</th><th>Receipt Date</th><th>Realized Date</th><th>Team</th><th class="text-end">Amount</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.ChequesCollected)
                            {
                                <tr>
                                    <td class="fw-bold">
                                        <a asp-controller="Collection"
                                           asp-action="ReceiptDetails"
                                           asp-route-receiptNo="@row.ReceiptNo"
                                           asp-route-team="@row.Team"
                                           class="text-decoration-none">
                                            @row.ReceiptNo
                                        </a>
                                    </td>
                                    <td><span class="text-muted small fw-semibold">@row.ChequeNo</span></td>
                                    <td><span class="text-muted small">@(row.PayDate.HasValue? row.PayDate.Value.ToString("yyyy-MM-dd") : "-")</span></td>
                                    <td><span class="text-muted small">@(row.RealizedDate.HasValue? row.RealizedDate.Value.ToString("yyyy-MM-dd") : "-")</span></td>
                                    <td>@row.Team</td>
                                    <td class="text-end fw-bold">@row.TotalAmount.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-light fw-bold text-dark d-flex justify-content-between">
                    <span>Cheques Deposited</span>
                    <span class="text-warning">@Model.ChequesDeposited.Sum(x => x.TotalAmount).ToString("N0") LKR</span>
                </div>
                <div class="card-body p-0 table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-secondary sticky-top">
                            <tr><th>Receipt No</th><th>Cheque No</th><th>Deposited Date</th><th>Team</th><th class="text-end">Amount</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.ChequesDeposited)
                            {
                                <tr>
                                    <td class="fw-bold">
                                        <a asp-controller="Collection"
                                           asp-action="ReceiptDetails"
                                           asp-route-receiptNo="@row.ReceiptNo"
                                           asp-route-team="@row.Team"
                                           class="text-decoration-none">
                                            @row.ReceiptNo
                                        </a>
                                    </td>
                                    <td><span class="text-muted small fw-semibold">@row.ChequeNo</span></td>
                                    <td><span class="text-muted small">@(row.DepositedDate.HasValue? row.DepositedDate.Value.ToString("yyyy-MM-dd") : "-")</span></td>
                                    <td>@row.Team</td>
                                    <td class="text-end fw-bold">@row.TotalAmount.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>


    </div>
</div>