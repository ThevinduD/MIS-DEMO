@model MIS_DEMO.Models.ViewModels.TopStockItemsKpiAjaxModel

@{
    ViewData["Title"] = "All Stock Items";
}

<div class="d-flex justify-content-between align-items-top mb-3 mt-4 px-md-3">
    <div>
        <h4 class="fw-bold mb-0">Total Stock Item Details</h4>
        <small class="text-muted">Currently available stock quantities</small>
    </div>
    <div>
        <a class="btn btn-sm btn-outline-secondary mt-1" href="javascript:history.back()">Back</a>
    </div>
</div>

<div class="px-md-3">
    <div class="card mb-3 shadow-sm border-0 bg-light">
        <div class="card-body p-2">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" id="filterItem" class="form-control form-control-sm" placeholder="Search Item Name..." />
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
                <table class="table table-striped table-hover align-middle mb-0 table-sm" id="stockTable">
                    <thead class="table-light sticky-top shadow-sm">
                        <tr>
                            <th class="ps-3">Item Name</th>
                            <th class="text-end pe-4">Total Quantity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.TopItems.Any())
                        {
                            <tr><td colspan="2" class="text-center py-4 text-muted">No stock items found.</td></tr>
                        }
                        else
                        {
                            foreach (var item in Model.TopItems)
                            {
                                <tr>
                                    <td class="ps-3 fw-semibold text-dark">@item.ItemName</td>
                                    <td class="text-end pe-4 fw-bold text-primary">@item.TotalQuantity.ToString("N0")</td>
                                </tr>
                            }
                        }
                    </tbody>
                    @if (Model.TopItems.Any())
                    {
                        <tfoot class="table-dark sticky-bottom">
                            <tr>
                                <td class="text-end fw-bold">GRAND TOTAL:</td>
                                <td class="text-end fw-bold pe-4 text-warning">
                                    @Model.TopItems.Sum(x => x.TotalQuantity).ToString("N0")
                                </td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const filterInput = document.getElementById("filterItem");
            const table = document.getElementById("stockTable");
            if (!table) return;

            const rows = Array.from(table.querySelector("tbody").querySelectorAll("tr"));

            // Cache data for fast filtering
            const cache = rows.map(r => {
                // Check if it's the "No data" row
                if (r.cells.length < 2) return null;
                return {
                    row: r,
                    itemName: r.cells[0].innerText.toLowerCase()
                };
            }).filter(x => x !== null);

            filterInput.addEventListener("input", function () {
                const term = filterInput.value.toLowerCase();
                cache.forEach(x => {
                    if (x.itemName.includes(term)) {
                        x.row.style.display = "";
                    } else {
                        x.row.style.display = "none";
                    }
                });
            });
        });
    </script>
}