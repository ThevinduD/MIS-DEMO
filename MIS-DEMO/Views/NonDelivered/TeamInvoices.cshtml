@model MIS_DEMO.Models.ViewModels.TeamInvoicesViewModel

@{
    ViewData["Title"] = "Pending Invoices";

    decimal ToK(decimal amt) => amt / 1000m;
    string KText(decimal amt) => $"{Math.Round(ToK(amt), 1):0.0}K";
}

<div class="d-flex justify-content-between align-items-start mb-2">
    <div>
        <h4 class="fw-bold mb-0">@ViewBag.Title</h4>
        <small class="text-muted">@ViewBag.SubTitle</small>

        @if (Model.IsTruncated)
        {
            <div class="mt-1">
                <span class="badge text-bg-warning">
                    Showing top @Model.MaxRows of @Model.TotalRows invoices
                </span>
            </div>
        }
    </div>

    <div class="text-end">
        <a class="btn btn-sm btn-outline-secondary mt-1" href="javascript:history.back()">Back</a>
    </div>
</div>

<!-- CLIENT-SIDE FILTERS (no submit / no navigation) -->
<div class="card mb-3 shadow-sm">
    <div class="card-body p-2">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-2">
                <label class="form-label small mb-1">Team</label>
                <input type="text" class="form-control form-control-sm" value="@Model.Team" readonly />
            </div>

            <div class="col-12 col-md-3">
                <label class="form-label small mb-1">Invoice No</label>
                <input type="text"
                       id="filterInvoice"
                       class="form-control form-control-sm"
                       placeholder="Search invoice..."
                       list="invList" />
                <datalist id="invList"></datalist>
            </div>

            <div class="col-12 col-md-3">
                <label class="form-label small mb-1">Rep</label>
                <input type="text"
                       id="filterRep"
                       class="form-control form-control-sm"
                       placeholder="Search rep..."
                       list="repList" />
                <datalist id="repList"></datalist>
            </div>

            <div class="col-12 col-md-3">
                <label class="form-label small mb-1">Customer</label>
                <input type="text"
                       id="filterCustomer"
                       class="form-control form-control-sm"
                       placeholder="Search customer..."
                       list="cusList" />
                <datalist id="cusList"></datalist>
            </div>

            <div class="col-6 col-md-1">
                <button type="button" class="btn btn-sm btn-primary w-100" id="btnApplyFilters">
                    Apply
                </button>
            </div>

            <div class="col-6 col-md-1">
                <button type="button" class="btn btn-sm btn-secondary w-100" id="btnClearFilters">
                    Clear
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Totals -->
<div class="row g-2 mb-3">
    <div class="col-12 col-md-4">
        <div class="card">
            <div class="card-body p-2">
                <div class="text-muted fw-semibold">Total Amount (Shown Rows)</div>
                <div class="fs-5 fw-bold" id="kpiTotalAmount">@KText(Model.TotalAmount)</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="card">
            <div class="card-body p-2">
                <div class="text-muted fw-semibold">Invoice Count (Shown Rows)</div>
                <div class="fs-5 fw-bold" id="kpiCount">@((Model.Rows?.Count ?? 0).ToString("N0"))</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0 table-sm small" id="invTable">
                <thead class="table-light">
                    <tr>
                        <th style="min-width:110px;">Date</th>
                        <th style="min-width:120px;">Invoice</th>
                        <th style="min-width:220px;">Customer</th>
                        <th style="min-width:160px;">Rep</th>
                        <th class="text-end" style="min-width:110px;">Amount</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Rows == null || !Model.Rows.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-3 text-muted">
                                No invoices found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var r in Model.Rows)
                        {
                            var cusDisplay = string.IsNullOrWhiteSpace(r.CusName) ? r.CusCode : r.CusName;
                            var repDisplay = string.IsNullOrWhiteSpace(r.SalesRepName) ? r.SalesRepCode : r.SalesRepName;

                            <tr>
                                <td>@(r.RefDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td class="fw-semibold">@r.InvoDocNo</td>
                                <td>@cusDisplay</td>
                                <td>@repDisplay</td>
                                <td class="text-end fw-bold" data-amt="@r.Amount">@KText(r.Amount)</td>
                            </tr>
                        }
                    }
                </tbody>

                <tfoot class="table-light fw-bold">
                    <tr>
                        <td colspan="4" class="text-end">TOTAL</td>
                        <td class="text-end text-primary" id="tableTotal">@KText(Model.Rows?.Sum(x => x.Amount) ?? 0)</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="small text-muted p-2">
            Amounts shown in K (1K = 1,000 LKR)
        </div>
    </div>
</div>

<!-- Loading overlay -->
<div id="loadingOverlay"
     class="position-fixed top-0 start-0 w-100 h-100 d-none align-items-center justify-content-center"
     style="background: rgba(255,255,255,0.6); z-index: 1055;">
    <div class="text-center">
        <div class="spinner-border text-primary mb-2" role="status"></div>
        <div class="fw-semibold small text-muted">Filtering…</div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const overlay = document.getElementById("loadingOverlay");

        const invoiceInput = document.getElementById("filterInvoice");
        const repInput = document.getElementById("filterRep");
        const customerInput = document.getElementById("filterCustomer");

        const invList = document.getElementById("invList");
        const repList = document.getElementById("repList");
        const cusList = document.getElementById("cusList");

        const table = document.getElementById("invTable");
        const tbodyRows = Array.from(table.querySelectorAll("tbody tr"))
            // keep only data rows (skip "No invoices found" row)
            .filter(r => r.cells && r.cells.length === 5);

        const kpiCount = document.getElementById("kpiCount");
        const kpiTotalAmount = document.getElementById("kpiTotalAmount");
        const tableTotal = document.getElementById("tableTotal");

        function showLoading() {
            overlay?.classList.remove("d-none");
            overlay?.classList.add("d-flex");
        }
        function hideLoading() {
            overlay?.classList.add("d-none");
            overlay?.classList.remove("d-flex");
        }

        function toKText(amount) {
            const k = amount / 1000.0;
            // 1 decimal place
            return `${(Math.round(k * 10) / 10).toFixed(1)}K`;
        }

        // Build cache + datalists from current table rows (client-side)
        const cache = tbodyRows.map(r => {
            const date = (r.cells[0].innerText || "").trim();
            const inv = (r.cells[1].innerText || "").trim();
            const cus = (r.cells[2].innerText || "").trim();
            const rep = (r.cells[3].innerText || "").trim();

            const amtCell = r.cells[4];
            const amtAttr = amtCell.getAttribute("data-amt");
            const amt = amtAttr ? (parseFloat(amtAttr) || 0) : 0;

            return {
                row: r,
                date,
                invLower: inv.toLowerCase(),
                repLower: rep.toLowerCase(),
                cusLower: cus.toLowerCase(),
                amt
            };
        });

        function fillDatalist(dlElem, values, limit = 500) {
            if (!dlElem) return;
            dlElem.innerHTML = "";
            values.slice(0, limit).forEach(v => {
                const opt = document.createElement("option");
                opt.value = v;
                dlElem.appendChild(opt);
            });
        }

        function buildDatalists() {
            const invSet = new Set();
            const repSet = new Set();
            const cusSet = new Set();

            cache.forEach(x => {
                // store original (not lower) by reading again from DOM to keep case
                const inv = (x.row.cells[1].innerText || "").trim();
                const rep = (x.row.cells[3].innerText || "").trim();
                const cus = (x.row.cells[2].innerText || "").trim();

                if (inv) invSet.add(inv);
                if (rep) repSet.add(rep);
                if (cus) cusSet.add(cus);
            });

            fillDatalist(invList, Array.from(invSet).sort((a,b) => a.localeCompare(b)));
            fillDatalist(repList, Array.from(repSet).sort((a,b) => a.localeCompare(b)));
            fillDatalist(cusList, Array.from(cusSet).sort((a,b) => a.localeCompare(b)));
        }

        function applyFilters() {
            const invF = (invoiceInput.value || "").trim().toLowerCase();
            const repF = (repInput.value || "").trim().toLowerCase();
            const cusF = (customerInput.value || "").trim().toLowerCase();

            let visibleCount = 0;
            let visibleAmt = 0;

            for (const x of cache) {
                const ok =
                    x.invLower.includes(invF) &&
                    x.repLower.includes(repF) &&
                    x.cusLower.includes(cusF);

                x.row.style.display = ok ? "" : "none";

                if (ok) {
                    visibleCount += 1;
                    visibleAmt += x.amt;
                }
            }

            if (kpiCount) kpiCount.innerText = visibleCount.toLocaleString("en-US");
            if (kpiTotalAmount) kpiTotalAmount.innerText = toKText(visibleAmt);
            if (tableTotal) tableTotal.innerText = toKText(visibleAmt);
        }

        function clearFilters() {
            invoiceInput.value = "";
            repInput.value = "";
            customerInput.value = "";
            applyFilters();
        }

        // Buttons
        document.getElementById("btnApplyFilters")?.addEventListener("click", () => {
            showLoading();
            setTimeout(() => { applyFilters(); hideLoading(); }, 10);
        });

        document.getElementById("btnClearFilters")?.addEventListener("click", () => {
            showLoading();
            setTimeout(() => { clearFilters(); hideLoading(); }, 10);
        });

        // Enter key = apply (no form submit)
        [invoiceInput, repInput, customerInput].forEach(inp => {
            inp.addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    showLoading();
                    setTimeout(() => { applyFilters(); hideLoading(); }, 10);
                }
            });
        });

        // Build datalists once from table, and compute initial totals
        buildDatalists();
        applyFilters();

        // safety: hide on bfcache restore
        window.addEventListener("pageshow", hideLoading);
    });
</script>