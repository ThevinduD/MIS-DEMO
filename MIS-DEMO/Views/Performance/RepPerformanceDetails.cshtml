@model MIS_DEMO.Models.ViewModels.RepPerformanceDetailsViewModel

@{
    ViewData["Title"] = $"Rep Performance - {Model.MonthLabel}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="fw-bold mb-0">Sales Rep Performance</h4>
        <small class="text-muted">Filtered for @Model.MonthLabel</small>
    </div>
    <div class="text-end">
        <a class="btn btn-sm btn-outline-secondary mt-1" href="javascript:history.back()">Back</a>
    </div>
</div>

<div class="card mb-3 shadow-sm">
    <div class="card-body p-2">
        <div class="row g-2">
            <div class="col-md-3">
                <input type="text" id="filterTeam" class="form-control form-control-sm" placeholder="Search Team..." list="teamList" />
                <datalist id="teamList"></datalist>
            </div>
            <div class="col-md-2">
                <input type="text" id="filterCode" class="form-control form-control-sm" placeholder="Search Code..." list="codeList" />
                <datalist id="codeList"></datalist>
            </div>
            <div class="col-md-3">
                <input type="text" id="filterName" class="form-control form-control-sm" placeholder="Search Rep Name..." list="nameList" />
                <datalist id="nameList"></datalist>
            </div>
            <div class="col-md-2">
                <button type="button" class="btn btn-sm btn-primary w-100" id="btnApplyFilters">Apply</button>
            </div>
            <div class="col-md-2">
                <button type="button" class="btn btn-sm btn-secondary w-100" id="btnClearFilters">Clear</button>
            </div>
        </div>
    </div>
</div>

