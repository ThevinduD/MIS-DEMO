@model MIS_DEMO.Models.ViewModels.LoginKpiAjaxModel

<div class="card shadow-sm border-0 h-100 text-white" style="background-color: #0d9488;">
    <div class="card-body p-3">

        <div class="d-flex justify-content-between align-items-start mb-3">
            <div class="d-flex flex-column">
                <h5 class="card-title m-0">System Logins</h5>
                <h6 class="card-subtitle text-white-50 mt-1">Today</h6>
            </div>
            <a asp-controller="Home" asp-action="LoginHistory"
               class="btn btn-sm rounded-2 bg-white shadow-sm fw-bold"
               style="color: #0d9488;">
                View
            </a>
        </div>

        <div class="mt-4">
            <span class="fs-1 fw-bold kpi-number">@Model.TodayLoginCount.ToString("N0")</span>
            <span class="kpi-currency text-white-50 ms-1">Users Logged In</span>
        </div>

    </div>
</div>
