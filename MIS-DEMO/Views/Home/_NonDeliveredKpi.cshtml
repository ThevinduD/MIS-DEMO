@model MIS_DEMO.Models.ViewModels.NonDeliveredKpiViewModel

<div class="card text-white h-100 bg-dark">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div class="d-flex flex-column">
                <h5 class="card-title m-0">Non Delivered Inv..</h5>
            </div>
            <a asp-controller="NonDelivered"
               asp-action="Invoices"
               class="btn btn-sm rounded-2 bg-white shadow-sm"
               style="font-size: 1.1rem; font-weight: 700; text-decoration:none; color:#343a40;"
               onclick="passNonDeliveredFilters(event)">
                View
            </a>
        </div>

        <div class="row g-2 mb-3">
            <div class="col-6">
                <select class="form-select form-select-sm bg-secondary text-white border-secondary shadow-none w-100" id="ndTeam" onchange="reloadNonDeliveredKpi()">
                    <option value="All" selected="@(Model.SelectedTeam == "All")">Team: All</option>
                    @foreach (var t in Model.AvailableTeams)
                    {
                        <option value="@t" selected="@(Model.SelectedTeam == t)">Team: @t</option>
                    }
                </select>
            </div>

            <div class="col-6">
                <select class="form-select form-select-sm bg-secondary text-white border-secondary shadow-none w-100" id="ndCategory" onchange="reloadNonDeliveredKpi()">
                    <option value="All" selected="@(Model.SelectedCategory == "All")">Type: All</option>
                    @foreach (var c in Model.AvailableCategories)
                    {
                        <option value="@c" selected="@(Model.SelectedCategory == c)">@c</option>
                    }
                </select>
            </div>

            <div class="col-12">
                <select class="form-select form-select-sm bg-secondary text-white border-secondary shadow-none w-100" id="ndDays" onchange="reloadNonDeliveredKpi()">
                    @foreach (var d in Model.AvailableDays)
                    {
                        <option value="@d" selected="@(Model.RangeDays == d)">Range: @d Days</option>
                    }
                </select>
            </div>
        </div>

        <div>
            <div class="kpi-container d-flex justify-content-between align-items-center border-bottom border-secondary pb-1 mb-1">
                <h6 class="text-light mb-0">Under @Model.RangeDays: </h6>
                <div>
                    <span class="fs-5 fw-bold">@Model.UnderAmount.ToString("N0")</span>
                    <small class="text-muted ms-1">LKR</small>
                </div>
            </div>
            <div class="kpi-container d-flex justify-content-between align-items-center">
                <h6 class="text-warning fw-bold mb-0">Over @Model.RangeDays: </h6>
                <div>
                    <span class="fs-5 fw-bold">@Model.OverAmount.ToString("N0")</span>
                    <small class="text-muted ms-1">LKR</small>
                </div>
            </div>
        </div>
    </div>
</div>