@model MIS_DEMO.Models.ViewModels.DeliveredKpiViewModel

<div class="card text-white h-100" style="background-color:#343a40;">
    <div class="card-body p-3">

        <div class="d-flex justify-content-between align-items-start mb-2">
            <div class="d-flex flex-column">
                <h5 class="card-title m-0">Delivered Invoices</h5>
                
            </div>
            <a asp-controller="Delivered"
               asp-action="Invoices"
               class="btn btn-sm rounded-2 bg-white shadow-sm"
               style="font-size: 1.1rem; font-weight: 700; text-decoration:none; color:#343a40;"
               onclick="passDeliveredFilters(event)">
                View
            </a>
        </div>

        <div class="row g-2 mb-3 mt-1">
            <div class="col-6">
                <select class="form-select form-select-sm bg-secondary text-white border-secondary shadow-none w-100" id="delTeam" onchange="reloadDeliveredKpi()">
                    <option value="All" selected="@(Model.SelectedTeam == "All")">Team: All</option>
                    @foreach (var t in Model.AvailableTeams)
                    {
                        <option value="@t" selected="@(Model.SelectedTeam == t)">Team: @t</option>
                    }
                </select>
            </div>

            <div class="col-6">
                <select class="form-select form-select-sm bg-secondary text-white border-secondary shadow-none w-100" id="delCategory" onchange="reloadDeliveredKpi()">
                    <option value="All" selected="@(Model.SelectedCategory == "All")">Type: All</option>
                    @foreach (var c in Model.AvailableCategories)
                    {
                        <option value="@c" selected="@(Model.SelectedCategory == c)">@c</option>
                    }
                </select>
            </div>
        </div>

        <div>
            <span class="fs-2 fw-bold kpi-number">@Model.ThisMonthDeliveredTotal.ToString("N0")</span>
            <span class="kpi-currency fs-6">LKR</span>
        </div>

    </div>
</div>