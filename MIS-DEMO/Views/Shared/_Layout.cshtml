@{
    var u = Context.Session.GetString("Username");
    var isAdmin = (u == "IT01" || u == "b");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MIS Cliniqon</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        body {
            padding-top: 56px;
            background-color: #f8fafc;
        }

        /* Main content */
        .content {
            padding: 20px;
            padding-left: 40px;
            padding-right: 40px;
        }

        /* Mobile adjustments */
        @@media (max-width: 991.98px) {
            .content {
                margin-left: 0;
                padding: 15px;
            }
        }

        #mobileMenu {
            transition: all 0.3s ease;
        }

        <!-- HomePage Styles -->
        .card {
            border-radius: 14px;
        }

        .kpi-number {
            font-size: 1.6rem;
            font-weight: 700;
            margin: 0;
            letter-spacing: 0.5px;
        }

        .kpi-currency {
            font-size: 1.4rem;
            font-weight: 500;
            color: #d1d5db;
        }

        .kpi-container {
            display: flex;
            align-items: baseline; /* Aligns text along the bottom edge */
            gap: 10px; /* Adds space between the elements */
        }

            /* Remove default margins that push elements apart */
            .kpi-container h5,
            .kpi-container p {
                margin: 0;
            }

        .logout-btn {
            font-size: 1rem; 
            padding: 0.375rem 0.75rem; 
            border-radius: 0.25rem; 
            color: #fff !important; 
            font-weight: 600;
        }

        .newuser-btn {
            padding: 0.375rem 0.75rem;
            border-radius: 0.25rem;
        }

        .newuser-btn a {
            font-size: 1rem;
            color: #fff !important;
            font-weight: 600;
        }

        .bg-teal {
            background-color: #004040 !important; /* modern teal */
        }

        .bg-teal .table > :not(caption) > * > * {
            color: #ffffff !important; /* force table text white */
            background-color: transparent !important;
        }

        .bg-yellow {
            background-color: #a97142 !important; /* modern teal */
        }

        .bg-yellow .table > :not(caption) > * > * {
            color: #ffffff !important;
            background-color: transparent !important;
        }

        .bg-grey {
            background-color: #A6A6A6 !important;
        }

        .bg-grey .table > :not(caption) > * > * {
            background-color: transparent !important;
        }

        .bg-pink {
            background-color: #fca5a5 !important;
        }

        .bg-pink .table > :not(caption) > * > * {
            background-color: transparent !important;
        }


        <!-- Sales Page Styles -->
        .toggle-btn {
            transition: all 0.2s ease;
        }

        .toggle-btn.active {
            background-color: #0d3b66 !important;
            border-color: #000000 !important;
            box-shadow: inset 0 0 0 2px rgba(255,255,255,0.25);
        }

        .sales-summary-table th {
            background-color: #0d3b66;
            color: #fff;
        }

        .sales-summary-table th,
        .sales-summary-table td {
            font-weight: 600;
            font-size: 1rem;
        }

        .sales-summary-table td {
            background-color: #fff;
        }

        <!---->
        .inv-summary-table th {
            background-color: #343a40;
            color: #fff;
        }

        .inv-summary-table th,
        .inv-summary-table td {
            font-weight: 600;
            font-size: 1rem;
        }

        .inv-summary-table td {
            background-color: #fff;
        }

        <!-- Active btn chart -->
        .period-btn.active {
            filter: brightness(0.75);
        }


    </style>


</head>
<body>
    <!-- Top NavBar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand mx-lg-2"
               asp-controller="Home"
               asp-action="Index">
                Cliniqon Biotech MIS
            </a>

            <button class="navbar-toggler" type="button" id="sidebarToggle">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav">
                    @* Admin menu item *@
                    @if (isAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="NaPasswords">Admin: Users</a>
                        </li>
                    }

                    <li class="nav-item d-flex align-items-center mx-2">
                        <span class="navbar-text text-white">
                            Hello, @Context.Session.GetString("RealName")
                        </span>
                    </li>
                    <li class="nav-item d-flex align-items-center mx-2">
                        <span class="navbar-text text-white">
                            @Context.Session.GetString("UserType")
                        </span>
                    </li>
                    <li class="nav-item d-flex align-items-center mx-2">
                        <span class="navbar-text text-white">
                            @Context.Session.GetString("SalesRepCode")
                        </span>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-link nav-link">Logout</button>
                        </form>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <!-- Mobile Dropdown Menu -->
    <div id="mobileMenu" class="d-lg-none position-fixed top-56 start-0 w-100 bg-dark text-white p-3" style="display:none; z-index:1050;">

        <p class="mb-1"><strong>Hello, @Context.Session.GetString("RealName")</strong></p>
        <p class="mb-1">User Type: @Context.Session.GetString("UserType")</p>
        <p class="mb-3">Rep Code: @Context.Session.GetString("SalesRepCode")</p>
        <div class="d-flex gap-2">
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                <button type="submit" class="btn btn-danger btn-sm logout-btn">Logout</button>
            </form>
            @if (isAdmin)
            {
                <button class="btn btn-sm btn-success newuser-btn">
                    <a class="text-decoration-none" asp-controller="Admin"
                       asp-action="NaPasswords">
                        New Users
                    </a>
                </button>
            }
        </div>
    </div>


    <!-- Main Content -->
    <div class="content">
        @RenderBody()
    </div>

    <script>
        const toggleBtn = document.getElementById('sidebarToggle');
        const mobileMenu = document.getElementById('mobileMenu');

        toggleBtn?.addEventListener('click', () => {
            if (mobileMenu.style.display === 'none' || mobileMenu.style.display === '') {
                mobileMenu.style.display = 'block';
            } else {
                mobileMenu.style.display = 'none';
            }
        });

    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
