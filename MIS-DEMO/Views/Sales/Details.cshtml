@{
    ViewData["Title"] = "Sales Details";
}

<div class="container mt-2 px-0">

    <div>
        <div class="text-end mb-3">
            <a class="btn btn-sm btn-outline-secondary mt-1" href="javascript:history.back()">Back</a>
        </div>
    </div>

    <!-- Title -->
    <h4 class="text-center mb-4 mt-5 text-decoration-underline">
        Sales Summary - Primary
    </h4>

    <!-- Sales Summary Table -->
    <div class="table-responsive">
        <table class="table table-bordered text-center sales-summary-table">
            <colgroup>
                <col style="width: 21%;">
                <col style="width: 21%;">
                <col style="width: 21%;">
                <col style="width: 21%;">
                <col style="width: 16%;">
            </colgroup>

            <thead>
                <tr>
                    <th></th>
                    <th>Sales</th>
                    <th>Return</th>
                    <th>NET</th>
                    <th>View</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <th>Today</th>
                    <td>@Model.TodaySales.ToString("N0")</td>
                    <td>@Model.TodayReturns.ToString("N0")</td>
                    <td class="fw-bold">
                        @Model.TodayNet.ToString("N0")
                    </td>
                    <td>
                        <a asp-controller="Sales"
                           asp-action="PeriodDetails"
                           asp-route-period="today"
                           class="mis-view-btn">
                            View
                        </a>
                    </td>
                </tr>
                <tr>
                    <th>Yesterday</th>
                    <td>@Model.YesterdaySales.ToString("N0")</td>
                    <td>@Model.YesterdayReturns.ToString("N0")</td>
                    <td class="fw-bold">
                        @Model.YesterdayNet.ToString("N0")
                    </td>
                    <td>
                        <a asp-controller="Sales"
                           asp-action="PeriodDetails"
                           asp-route-period="yesterday"
                           class="mis-view-btn">
                            View
                        </a>
                    </td>

                </tr>
                <tr>
                    <th>This Month</th>
                    <td>@Model.ThisMonthSales.ToString("N0")</td>
                    <td>@Model.ThisMonthReturns.ToString("N0")</td>
                    <td class="fw-bold">
                        @Model.ThisMonthNet.ToString("N0")
                    </td>
                    <td>
                        <a asp-controller="Sales"
                           asp-action="PeriodDetails"
                           asp-route-period="thismonth"
                           class="mis-view-btn">
                            View
                        </a>
                    </td>
                </tr>
                <tr>
                    <th>Last Month</th>
                    <td>@Model.LastMonthSales.ToString("N0")</td>
                    <td>@Model.LastMonthReturns.ToString("N0")</td>
                    <td class="fw-bold">
                        @Model.LastMonthNet.ToString("N0")
                    </td>
                    <td>
                        <a asp-controller="Sales"
                           asp-action="PeriodDetails"
                           asp-route-period="lastmonth"
                           class="mis-view-btn">
                            View
                        </a>
                    </td>
                </tr>
                <tr>
                    <th style="background-color:purple">Select</th>
                    <td>
                        <a asp-controller="Sales"
                           asp-action="PeriodDetails"
                           asp-route-period="select"
                           class="mis-view-btn">
                            View
                        </a>
                    </td>
                </tr>
            </tbody>
        </table>

    </div>

    <!-- Next Section -->
    <h4 class="text-center mt-5 text-decoration-underline">
        Product Wise Sale - Primary
    </h4>

    <div class="row mt-4">
        <div class="col-12 col-lg-6 mb-3">
            <div class="card">
                <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2 px-2">
                    <!-- Period buttons -->
                    <div class="d-flex flex-wrap justify-content-between gap-1 w-100" aria-label="Quick ranges">
                        <button type="button" class="btn btn-sm btn-success period-btn active" data-period="today">
                            Today
                        </button>
                        <button type="button" class="btn btn-sm btn-success period-btn" data-period="yesterday">
                            Yesterday
                        </button>
                        <button type="button" class="btn btn-sm btn-success period-btn" data-period="thismonth">
                            This-M
                        </button>
                        <button type="button" class="btn btn-sm btn-success period-btn" data-period="lastmonth">
                            Last-M
                        </button>
                    </div>

                    <!-- Filters -->
                    <div class="d-flex align-items-start gap-3 flex-wrap mt-2 w-100">
                        <div class="d-flex align-items-center justify-content-between w-50">
                            <span class="text-muted small">From</span>
                            <input id="salesFrom" type="date"
                                   class="form-control form-control-sm shadow-sm"
                                   style="width: 130px;" />
                        </div>

                        <div class="d-flex align-items-center justify-content-between w-50">
                            <span class="text-muted small">To</span>
                            <input id="salesTo" type="date"
                                   class="form-control form-control-sm shadow-sm"
                                   style="width: 130px;" />
                        </div>

                        <!-- THIS is the key -->
                        <div class="ms-auto">
                            <select id="metricSelect"
                                    class="form-select form-select-sm shadow-sm"
                                    style="width: 100px;">
                                <option value="value" selected>Value</option>
                                <option value="qty">Qty</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <canvas id="inventoryChart" height="250"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Second Section -->
    <h4 class="text-center mt-5 text-decoration-underline">
        Today / Yesterday Sales - Primary
    </h4>

    <div class="row mt-4">
        <div class="col-12 col-lg-6 mb-3">
            <div class="card">
                <div class="card-header">Today / Yesterday Sales</div>
                <div class="card-body">
                    <canvas id="dayWiseChart" height="300"></canvas>
                </div>
            </div>
        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", () => {

      // ---------- URLs (IIS safe) ----------
      const productWiseUrl = '@Url.Action("ProductWiseData", "Sales")';
      const dayWiseUrl = '@Url.Action("DayWiseSalesData", "Sales")';

      // ---------- helpers ----------
      const devToday = new Date("@ViewBag.TodayIso");

      function formatDateYYYYMMDD(d) {
        const year = d.getFullYear();
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const day = String(d.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      }

      // ---------- PIE ----------
      let inventoryChart;

      async function loadProductWiseChart(params) {
        try {
          const qs = new URLSearchParams(params);
          const resp = await fetch(`${productWiseUrl}?${qs.toString()}`, { cache: 'no-store' });
          if (!resp.ok) return;

          const data = await resp.json();
          const ctx = document.getElementById('inventoryChart')?.getContext('2d');
          if (!ctx) return;

          if (inventoryChart) inventoryChart.destroy();

          inventoryChart = new Chart(ctx, {
            type: 'pie',
            data: {
              labels: data.labels || [],
              datasets: [{
                label: params.metric === "qty" ? "Qty" : "Value",
                data: data.values || []
              }]
            },
            options: {
              responsive: true,
              plugins: {
                legend: { position: 'bottom' },
                tooltip: {
                  callbacks: {
                    label: function (context) {
                      const value = context.raw || 0;
                      if (params.metric === "qty") {
                        return `${context.label}: ${Number(value).toLocaleString()} qty`;
                      }
                      return `${context.label}: ${Number(value).toLocaleString()} LKR`;
                    }
                  }
                }
              }
            }
          });

        } catch (e) {
          console.error("ProductWiseData fetch failed:", e);
        }
      }

      const fromInput = document.getElementById("salesFrom");
      const toInput = document.getElementById("salesTo");
      const metricSelect = document.getElementById("metricSelect");
      const periodButtons = document.querySelectorAll(".period-btn");

      function setActiveButton(period) {
        periodButtons.forEach(b => b.classList.toggle("active", b.dataset.period === period));
      }

      function setRangeForPeriod(period) {
        let fromDate = new Date(devToday);
        let toDate = new Date(devToday);

        if (period === "yesterday") {
          fromDate.setDate(fromDate.getDate() - 1);
          toDate = new Date(fromDate);
        } else if (period === "thismonth") {
          fromDate = new Date(devToday.getFullYear(), devToday.getMonth(), 1);
          toDate = new Date(devToday.getFullYear(), devToday.getMonth() + 1, 0);
        } else if (period === "lastmonth") {
          fromDate = new Date(devToday.getFullYear(), devToday.getMonth() - 1, 1);
          toDate = new Date(devToday.getFullYear(), devToday.getMonth(), 0);
        }

        if (fromInput) fromInput.value = formatDateYYYYMMDD(fromDate);
        if (toInput) toInput.value = formatDateYYYYMMDD(toDate);
      }

      function loadByCurrentInputs(periodFallback = "today") {
        const metric = metricSelect?.value || "value";
        const from = fromInput?.value;
        const to = toInput?.value;

        if (from && to) return loadProductWiseChart({ from, to, metric });
        return loadProductWiseChart({ period: periodFallback, metric });
      }

      // init pie
      setActiveButton("today");
      setRangeForPeriod("today");
      loadByCurrentInputs("today");

      periodButtons.forEach(btn => {
        btn.addEventListener("click", () => {
          const period = btn.dataset.period || "today";
          setActiveButton(period);
          setRangeForPeriod(period);
          loadByCurrentInputs(period);
        });
      });

      fromInput?.addEventListener("change", () => loadByCurrentInputs());
      toInput?.addEventListener("change", () => loadByCurrentInputs());
      metricSelect?.addEventListener("change", () => loadByCurrentInputs());

      // ---------- LINE ----------
      const ctx = document.getElementById('dayWiseChart')?.getContext('2d');
      if (!ctx) return;

      const dayWiseChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: [],
          datasets: [
            { label: 'Today', data: [], borderWidth: 3, tension: 0.4, pointRadius: 3 },
            { label: 'Yesterday', data: [], borderWidth: 3, tension: 0.4, pointRadius: 3 }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'top' },
            tooltip: {
              callbacks: {
                label: (context) =>
                  `${context.dataset.label}: LKR ${(context.parsed.y || 0).toLocaleString()}`
              }
            }
          },
          scales: {
            y: { ticks: { callback: v => `LKR ${v.toLocaleString()}` } }
          }
        }
      });

      async function loadDayWise() {
        try {
          const res = await fetch(dayWiseUrl, { cache: 'no-store' });
          if (!res.ok) return;

          const data = await res.json();
          dayWiseChart.data.labels = data.labels || [];
          dayWiseChart.data.datasets[0].data = data.today || [];
          dayWiseChart.data.datasets[1].data = data.yesterday || [];
          dayWiseChart.update();
        } catch (e) {
          console.error("DayWiseSalesData fetch failed:", e);
        }
      }

      loadDayWise();
    });
</script>




