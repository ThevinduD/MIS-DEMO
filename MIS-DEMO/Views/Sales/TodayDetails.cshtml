@model MIS_DEMO.Models.ViewModels.TodaySalesDetailsViewModel

@{
    ViewData["Title"] = "Today Sales Details";
}

@if ((ViewBag.Period as string) == "select")
{
    <form asp-controller="Sales" asp-action="PeriodDetails" method="get" class="card mb-3 shadow-sm">
        <input type="hidden" name="period" value="select" />
        <div class="card-body p-2">
            <div class="row g-2 align-items-end">
                <div class="col-6 col-md-4">
                    <label class="form-label small mb-1">From</label>
                    <input type="date"
                           name="from"
                           class="form-control form-control-sm"
                           value="@Model.FromDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-6 col-md-4">
                    <label class="form-label small mb-1">To</label>
                    <input type="date"
                           name="to"
                           class="form-control form-control-sm"
                           value="@Model.ToDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-12 col-md-4">
                    <button type="submit" class="btn btn-primary btn-sm w-100">
                        Apply
                    </button>
                </div>
            </div>
        </div>
    </form>
}


<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="fw-bold mb-0">@ViewBag.PeriodTitle</h4>
        <small class="text-muted">@ViewBag.PeriodRange</small>

    </div>

    <a asp-controller="Sales" asp-action="Details" class="btn btn-outline-secondary btn-sm">
        Back
    </a>
</div>

<div class="card mb-3 shadow-sm">
    <div class="card-body p-2">
        <div class="row g-2">
            <div class="col-md-4">
                <input type="text" id="filterItem" class="form-control form-control-sm" placeholder="Search Item Name...">
            </div>
            <div class="col-md-3">
                <input type="text" id="filterRep" class="form-control form-control-sm" placeholder="Search Rep Name...">
            </div>
            <div class="col-md-3">
                <input type="text" id="filterCustomer" class="form-control form-control-sm" placeholder="Search Customer...">
            </div>
            <div class="col-md-2">
                <button class="btn btn-sm btn-secondary w-100" onclick="clearFilters()">Clear</button>
            </div>
        </div>
    </div>
</div>

<!-- Totals strip -->
<div class="row g-2 mb-3">
    <div class="col-12 col-md-4">
        <div class="card">
            <div class="card-body p-2">
                <div class="text-muted fw-semibold">Sales Total</div>
                <div class="fs-5 fw-bold">@Model.SalesTotal.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card">
            <div class="card-body p-2">
                <div class="text-muted fw-semibold">Return Total</div>
                <div class="fs-5 fw-bold">@Model.ReturnTotal.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="card">
            <div class="card-body p-2">
                <div class="text-muted fw-semibold">Net Total</div>
                <div class="fs-5 fw-bold">@Model.NetTotal.ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

<!-- SALES TABLE -->
<h5 class="fw-bold mt-4 mb-2">Sales (Item-wise)</h5>
<div class="card mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0" id="salesTable">
                <thead class="table-light">
                    <tr>
                        <th style="min-width:200px;">Item</th>
                        <th class="text-end" style="width:60px;">Qty</th>
                        <th class="text-end" style="min-width:100px;">Line Total</th>
                        <th style="min-width:120px;">Rep</th>
                        <th style="min-width:180px;">Customer</th>
                        <th style="min-width:140px;">Invoice</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.SalesLines.Any())
                    {
                        <tr><td colspan="8" class="text-center py-3 text-muted">No sales found.</td></tr>
                    }
                    else
                    {
                        foreach (var r in Model.SalesLines)
                        {
                            <tr>
                                <td>@r.Description</td>
                                <td class="text-end">@r.Qty.ToString("N0")</td>
                                <td class="text-end fw-bold">@r.LineTotal.ToString("N0")</td>
                                <td>@r.SalesRepName</td>
                                <td>@r.CusName</td>
                                <td>
                                    @r.InvoDocNo
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot class="table-light fw-bold">
                    <tr>
                        <td>TOTAL</td>
                        <td id="totalQty" class="text-end">0</td>
                        <td id="totalAmount" class="text-end text-primary">0</td>
                        <td colspan="3"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<!-- RETURNS TABLE -->
<h5 class="fw-bold mt-4 mb-2">Returns (Item-wise)</h5>
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="returnTable">
                <thead class="table-light">
                    <tr>
                        <th style="min-width:200px;">Item</th>
                        <th class="text-end" style="width:60px;">Qty</th>
                        <th class="text-end" style="min-width:100px;">Line Total</th>
                        <th style="min-width:120px;">Rep</th>
                        <th style="min-width:180px;">Customer</th>
                        <th style="min-width:140px;">Invoice</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.ReturnLines.Any())
                    {
                        <tr><td colspan="8" class="text-center py-4 text-muted">No returns found.</td></tr>
                    }
                    else
                    {
                        foreach (var r in Model.ReturnLines)
                        {
                            <tr>
                                <td>@r.Description</td>
                                <td class="text-end">@r.Qty.ToString("N0")</td>
                                <td class="text-end fw-bold">@r.LineTotal.ToString("N0")</td>
                                <td>@r.SalesRepName</td>
                                <td>@r.CusName</td>
                                <td>
                                    @r.InvoDocNo
                                    @r.RtnDocNo
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot class="table-light fw-bold">
                    <tr>
                        <td>TOTAL</td>
                        <td id="returnTotalQty" class="text-end">0</td>
                        <td id="returnTotalAmount" class="text-end text-primary">0</td>
                        <td colspan="3"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>


<script>
    document.addEventListener("DOMContentLoaded", function () {
      const itemInput = document.getElementById("filterItem");
      const repInput  = document.getElementById("filterRep");
      const cusInput  = document.getElementById("filterCustomer");

      function processTable(tableId, qtyLabelId, amtLabelId) {
        const table = document.getElementById(tableId);
        if (!table) return;

        const itemFilter = itemInput.value.toLowerCase();
        const repFilter  = repInput.value.toLowerCase();
        const cusFilter  = cusInput.value.toLowerCase();

        const rows = table.querySelectorAll("tbody tr");
        let runningQty = 0;
        let runningAmt = 0;

        rows.forEach(row => {
          // Skip "No sales found" rows (they have only 1 td with colspan)
          if (row.cells.length < 3) return;

          const itemName = row.cells[0].innerText.toLowerCase();
          const repName  = row.cells[3].innerText.toLowerCase();
          const cusName  = row.cells[4].innerText.toLowerCase();

          const qtyText = row.cells[1].innerText.replace(/[^-0-9.]/g, "");
          const amtText = row.cells[2].innerText.replace(/[^-0-9.]/g, "");

          const qtyValue   = parseFloat(qtyText) || 0;
          const totalValue = parseFloat(amtText) || 0;

          const matches =
            itemName.includes(itemFilter) &&
            repName.includes(repFilter) &&
            cusName.includes(cusFilter);

          row.style.display = matches ? "" : "none";

          if (matches) {
            runningQty += qtyValue;
            runningAmt += totalValue;
          }
        });

        const qtyElem = document.getElementById(qtyLabelId);
        const amtElem = document.getElementById(amtLabelId);

        if (qtyElem) qtyElem.innerText = runningQty.toLocaleString("en-US");
        if (amtElem) amtElem.innerText = runningAmt.toLocaleString("en-US");
      }

      function filterEverything() {
        // SALES footer ids in your html: totalQty, totalAmount
        processTable("salesTable", "totalQty", "totalAmount");

        // returns table id in your html: returnTable
        // (you currently have NO footer there, so this won’t display totals unless you add it)
        processTable("returnTable", "returnTotalQty", "returnTotalAmount");
      }

      [itemInput, repInput, cusInput].forEach(i => i.addEventListener("keyup", filterEverything));
      filterEverything();
    });

    function clearFilters() {
      document.getElementById("filterItem").value = "";
      document.getElementById("filterRep").value = "";
      document.getElementById("filterCustomer").value = "";
      document.getElementById("filterItem").dispatchEvent(new Event("keyup"));
    }
</script>

