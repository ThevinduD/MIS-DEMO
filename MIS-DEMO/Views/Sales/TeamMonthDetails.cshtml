@model MIS_DEMO.Models.ViewModels.TeamMonthDetailsViewModel

@{
    // 1. Title now shows the dynamic month (e.g. "Jan 2026")
    ViewData["Title"] = $"Team Sales ({Model.MonthLabel})";
    string ModeLabel(string m) => (m ?? "item").ToLower() switch
    {
        "rep" => "Rep",
        "customer" => "Customer",
        _ => "Item"
    };
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <h4 class="fw-bold mb-0">@Model.LocShort - @Model.MonthLabel (NET)</h4>
        <small class="text-muted">Mode: @ModeLabel(Model.Mode)</small>
    </div>
    <div class="text-end">
        <a class="btn btn-sm btn-outline-secondary mt-1" href="javascript:history.back()">Back</a>
    </div>
</div>

<form method="get" asp-controller="Sales" asp-action="TeamMonthDetails" class="card mb-3 shadow-sm">
    <input type="hidden" name="locShort" value="@Model.LocShort" />

    <input type="hidden" name="monthOffset" value="@Model.MonthOffset" />

    <div class="card-body p-2">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-2">
                <label class="form-label small mb-1">Team</label>
                <input type="text" class="form-control form-control-sm" value="@Model.LocShort" readonly />
            </div>

            <div class="col-12 col-md-2">
                <label class="form-label small mb-1">Filter by</label>
                <select class="form-select form-select-sm" name="mode">
                    <option value="item" selected="@(Model.Mode == "item")">Item</option>
                    <option value="rep" selected="@(Model.Mode == "rep")">Rep</option>
                    <option value="customer" selected="@(Model.Mode == "customer")">Customer</option>
                </select>
            </div>

            <div class="col-12 col-md-5">
                <label class="form-label small mb-1">Search</label>
                <input type="text"
                       name="search"
                       value="@Model.Search"
                       class="form-control form-control-sm"
                       placeholder="Type and press Apply..."
                       list="searchList" />

                <datalist id="searchList">
                    @foreach (var s in Model.Suggestions)
                    {
                        <option value="@s"></option>
                    }
                </datalist>

                <div class="small text-muted mt-1">
                    @if (Model.Mode == "item")
                    {
                        <span>Suggestions: items</span>
                    }
                    else if (Model.Mode == "rep")
                    {
                        <span>Suggestions: reps</span>
                    }
                    else
                    {
                        <span>Suggestions: customers</span>
                    }
                </div>
            </div>

            <div class="col-6 col-md-1">
                <button type="submit" class="btn btn-sm btn-primary w-100">Apply</button>
            </div>

            <div class="col-6 col-md-2">
                <a class="btn btn-sm btn-secondary w-100"
                   asp-controller="Sales"
                   asp-action="TeamMonthDetails"
                   asp-route-locShort="@Model.LocShort"
                   asp-route-mode="@Model.Mode"
                   asp-route-monthOffset="@Model.MonthOffset">
                    Clear Search
                </a>
            </div>
        </div>
    </div>
</form>

<div class="row g-2 mb-3">
    <div class="col-12 col-md-4">
        <div class="card">
            <div class="card-body p-2">
                <div class="text-muted fw-semibold">Net Total</div>
                <div class="fs-5 fw-bold">@Model.NetTotal.ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0 table-sm small">
                <thead class="table-light">
                    <tr>
                        @foreach (var c in Model.Columns)
                        {
                            <th class="@(c == "Qty" || c.Contains("Total") ? "text-end" : "")" style="min-width:120px;">@c</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @if (Model.TableRows == null || !Model.TableRows.Any())
                    {
                        <tr><td colspan="@(Model.Columns.Count)" class="text-center py-3 text-muted">No data found.</td></tr>
                    }
                    else
                    {
                        foreach (var row in Model.TableRows)
                        {
                            <tr>
                                @for (int i = 0; i < row.Count; i++)
                                {
                                    var colName = Model.Columns[i];
                                    var isNum = colName == "Qty" || colName.Contains("Total");
                                    <td class="@(isNum ? "text-end fw-bold" : "")">@row[i]</td>
                                }
                            </tr>
                        }
                    }
                </tbody>

                @if (Model.TableRows != null && Model.TableRows.Any())
                {
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td>@Model.FooterLabel</td>

                            @* Put totals in the LAST 2 numeric columns (Qty + Net Total), keep others blank *@
                            @for (int i = 1; i < Model.Columns.Count; i++)
                            {
                                var colName = Model.Columns[i];
                                if (colName == "Qty")
                                {
                                    <td class="text-end">@Model.FooterQty.ToString("N0")</td>
                                }
                                else if (colName.Contains("Total"))
                                {
                                    <td class="text-end text-primary">@Model.FooterAmount.ToString("N0")</td>
                                }
                                else
                                {
                                    <td></td>
                                }
                            }
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>